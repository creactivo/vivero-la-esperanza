---
import Layout from "../layouts/Layout.astro";
import AuthForm from "../components/AuthForm";
---

<Layout title="Iniciar sesión" description="Inicia sesión en tu cuenta">
    <!-- Header Section -->
    <div class="auth-header-section text-center">
        <span class="detail-badge">ACCESO MAYORISTA</span>
        <h1 class="main-title">INICIAR SESIÓN</h1>
        <p class="header-subtitle">Completa tus datos para acceder a tu cuenta</p>
    </div>

    <div class="auth-page">
        <div class="container">
            <AuthForm client:load mode="login" />
        </div>
    </div>
</Layout>

<script>
  import { auth } from '../lib/firebase';
  import { onAuthStateChanged } from 'firebase/auth';

  function getCurrentUser() {
    return new Promise((resolve, reject) => {
      const unsubscribe = onAuthStateChanged(auth, (user) => {
        unsubscribe();
        resolve(user);
      }, (error) => {
        unsubscribe();
        reject(error);
      });
    });
  }

  document.addEventListener('astro:page-load', async () => {
    try {
      const user = await getCurrentUser();
      if (user) {
        console.log('[login.astro] User is already logged in. Redirecting to /perfil.');
        window.location.href = '/perfil';
      }
    } catch (error) {
      console.error('[login.astro] Error checking auth state:', error);
    }
  });
</script>

<style>
    .auth-header-section {
        padding: 160px 0 40px;
        background: radial-gradient(
            circle at center,
            rgba(230, 240, 230, 0.5) 0%,
            transparent 70%
        );
        background-image: url("/images/hero-bg.jpg");
        background-size: cover;
        background-position: center bottom;
        background-repeat: no-repeat;
    }

    .detail-badge {
        background: #d8e2dc;
        color: #555;
        font-size: 0.65rem;
        padding: 6px 16px;
        border-radius: 12px;
        letter-spacing: 1px;
        text-transform: uppercase;
        font-weight: 600;
        display: inline-block;
        margin-bottom: 10px;
    }

    .main-title {
        font-size: 2.8rem;
        color: var(--color-primary);
        margin-bottom: 10px;
        letter-spacing: -1px;
        font-weight: 700;
    }

    .header-subtitle {
        color: var(--color-text-light);
        font-size: 1rem;
        margin-top: 10px;
    }

    .auth-page {
        padding: 60px 0;
        background: var(--color-background);
    }
</style>