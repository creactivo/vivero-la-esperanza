---
import { siInstagram, siFacebook, siPinterest } from "simple-icons";
---

<footer class="site-footer">
    <div class="container">
        <div class="footer-top">
            <div class="footer-col brand-col">
                <div class="footer-logo">
                    <img src="../images/logo-footer-horizontal-blanco.png" alt="Tienda Esperanza Vivero" class="footer-logo-img" width="150" height="auto" />
                </div>
                <p class="footer-desc">
                    Especialistas en la propagación, cultivo y venta de plantas 
                    ornamentales, frutales y forestales de la mejor calidad para tus 
                    espacios verdes.
                </p>
            </div>

            <div class="footer-col brand-col">
                <h4>Contacto</h4>
                <ul class="contact-list">
                    <li>Vía La Libertad, Sincerin, Arjona, Bolívar, Colombia</li>
                    <li>Email: contacto@viveroesperanza.com</li>
                    <li>Tel: +57 3052928924</li>
                </ul>
            </div>

            <div class="footer-col">
                <h4>Otros Enlaces</h4>
                <ul>
                    <li><a href="/carrito">Carrito</a></li>
                    <li><a href="/login">Mi cuenta</a></li>
                </ul>
            </div>

            <div class="footer-col">
                <h4>Enlaces</h4>
                <ul>
                    <li><a href="/">Inicio</a></li>
                    <li><a href="/nuestro-vivero">Nuestro Vivero</a></li>
                    <li><a href="/proyectos">Proyectos</a></li>
                </ul>
            </div>

            <div class="footer-col brand-col">
                <h4>Síguenos</h4>
                <div class="social-icons">
                    <a href="https://www.instagram.com/laesperanzavivero2026/" aria-label="Instagram" target="_blank" rel="noopener noreferrer">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                            <path d={siInstagram.path}/>
                        </svg>
                    </a>
                    <a href="https://www.facebook.com/profile.php?id=61586998268034" aria-label="Facebook" target="_blank" rel="noopener noreferrer">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                            <path d={siFacebook.path}/>
                        </svg>
                    </a>
                    <a href="https://www.pinterest.com/laesperanzavivero2026/" aria-label="Pinterest" target="_blank" rel="noopener noreferrer">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                            <path d={siPinterest.path}/>
                        </svg>
                    </a>
                </div>
            </div>
        </div>

        <div class="footer-bottom">
            <p>
                © {new Date().getFullYear()} Tienda Esperanza. Todos los derechos
                reservados.
            </p>
            <div class="legal-links">
                <a href="#">Términos y Condiciones</a>
                <a href="#">Política de Privacidad</a>
            </div>
        </div>
    </div>
</footer>

<style>
    /* Footer Styles */
    .site-footer {
        position: relative;
        background-color: var(--color-primary-dark);
        background-image: url("/footer-bg.jpg");
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        color: white;
        padding: var(--space-20) 0 var(--space-8);
        margin-top: var(--space-12);
        overflow: hidden; /* Ensure pseudo-element doesn't overflow */
    }

    .site-footer::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: linear-gradient(176deg, rgba(0, 102, 79, 0.76) 0%, var(--color-primary-dark) 100%);
        z-index: 1;
    }

    .site-footer > .container {
        position: relative;
        z-index: 2; /* Ensure content is above the gradient overlay */
    }

    .footer-top {
        display: grid;
        grid-template-columns: 1fr; /* Mobile-first: una debajo de otra */
        gap: var(--space-8);
        margin-bottom: var(--space-12);
        align-items: start;
    }

    @media (min-width: 768px) { /* Breakpoint md de Tailwind */
        .footer-top {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @media (min-width: 1024px) { /* Breakpoint lg de Tailwind */
        .footer-top {
            grid-template-columns: 2.5fr 1.2fr 1fr 1fr 1.2fr; /* Lado a lado en desktop */
        }
    }

    .brand-col {
        margin-bottom: 0;
    }

    .footer-logo {
        display: flex;
        flex-direction: column;
        width: fit-content;
        margin-bottom: 20px;
    }

    .brand-name-footer {
        font-size: 1.5rem;
        font-weight: 700;
        letter-spacing: 2px;
        color: white;
    }

    .brand-subtitle-footer {
        font-size: 0.6rem;
        letter-spacing: 4px;
        color: rgba(255, 255, 255, 0.8);
    }

    .footer-desc,
    .contact-list li {
        color: rgba(255, 255, 255, 0.9);
        line-height: 1.6;
        list-style: none;
    }

    .footer-col h4 {
        color: white;
        font-size: 1.1rem;
        margin-bottom: 20px;
        font-weight: 500;
    }

    .footer-col ul {
        list-style: none;
    }

    .footer-col ul li {
        margin-bottom: 10px;
    }

    .footer-col a {
        color: rgba(255, 255, 255, 0.7);
        text-decoration: none;
        transition: all 0.3s ease;
        display: inline-block;
    }

    .footer-col a:hover {
        color: white;
        text-decoration: none;
        transform: translateX(5px);
    }

    .social-icons a {
        color: rgba(255, 255, 255, 0.8);
        margin-right: 15px;
        font-size: 1.2rem;
        text-decoration: none;
        transition: all 0.3s ease;
        display: inline-block;
    }

    .social-icons a:hover {
        color: white;
        transform: translateY(-3px);
    }

    .footer-bottom {
        border-top: 1px solid rgba(255, 255, 255, 0.2);
        padding-top: 20px;
        display: flex;
        justify-content: space-between;
        color: rgba(255, 255, 255, 0.8);
    }

    .legal-links a {
        color: rgba(255, 255, 255, 0.6);
        text-decoration: none;
        margin-left: 20px;
        transition: color 0.3s ease;
    }

    .legal-links a:hover {
        color: white;
    }

    @media (max-width: 767px) {
        .footer-bottom {
            flex-direction: column;
            gap: 15px;
            text-align: center;
        }
    }
</style>