---
import Layout from "../layouts/Layout.astro";
import Cart from "../components/Cart";
---

<Layout title="Carrito de compras" description="Revisa tu carrito de compras">
    <div class="cart-page">
        <div class="container">
            <h1>CARRITO DE COMPRAS</h1>
            <Cart client:only="react" />
        </div>
    </div>
</Layout>
<!-- aca comienza el estilo del carrito de compras -->
<style>
    .cart-page {
        padding: 120px 0 60px;
        min-height: 60vh;
        background: var(--color-background);
    }

    .cart-page h1 {
        font-size: 2rem;
        margin-bottom: 40px;
        color: var(--color-primary);
        font-weight: 700;
        text-transform: uppercase;
    }
</style>