---
import Layout from "../layouts/Layout.astro";
import ProductCarousel from "../components/ProductCarousel.astro";
import ProductCard from "../components/ProductCard.astro"; // Importar ProductCard
import {
    getProductos,
    getCategorias,
    getSectionsPage,
    getImageUrl,
} from "../lib/strapi";
import type { Producto } from "../lib/strapi";

import { Leaf, Gift, Sprout, Scissors, Grid, List } from "lucide-react"; // Importar Grid y List

// 1. Obtener todos los datos en paralelo
const [productos, categorias, sectionsPage] = await Promise.all([
    getProductos(),
    getCategorias(),
    getSectionsPage(),
]);

// Extraer datos del hero dinámico
const heroData = sectionsPage?.componente;
const heroBgImage = heroData?.imagenbanner?.[0]
    ? getImageUrl(heroData.imagenbanner[0].url)
    : "/images/bg-hero-b.jpg";
const heroTitle = heroData?.heading || "CATALOGO";
const heroSubtitle = sectionsPage?.title || "BIENVENIDO A NUESTRO";
const heroDesc =
    heroData?.subheading ||
    "Descubre nuestra amplia variedad de plantas ornamentales, frutales y forestales. Cultivadas con amor para darle vida a tus espacios.";

// 2. Agrupar productos por categoría para los carruseles
const productosPorCategoria = new Map<string, Producto[]>();

for (const producto of productos) {
    if (producto.categoria) {
        const categoriaNombre = producto.categoria.nombre;
        if (!productosPorCategoria.has(categoriaNombre)) {
            productosPorCategoria.set(categoriaNombre, []);
        }
        productosPorCategoria.get(categoriaNombre)?.push(producto);
    }
}

// 3. Convertir el Map a un Array para usarlo en el template
const carruseles = Array.from(productosPorCategoria.entries());
---


<Layout title="Inicio">
    <!-- Hero / Catálogo Header -->
    <section
        class="hero-section"
        style={`background-image: url('${heroBgImage}');`}
    >
        <div class="container text-center">
            <span class="hero-subtitle">{heroSubtitle}</span>
            <h1 class="hero-title">{heroTitle}</h1>
            <p class="hero-desc">
                {heroDesc}
            </p>

            <!-- Buscador -->
            <div class="search-container">
                <form action="/" method="get" class="search-form">
                    <input
                        type="text"
                        name="q"
                        placeholder="Buscar..."
                        class="search-input"
                    />
                    <button type="submit" class="search-btn">BUSCAR</button>
                </form>
            </div>
        </div>
    </section>

    <!-- Filtros Rápidos (Categorías Dinámicas) -->
    <section class="quick-filters container">
        <div class="filter-grid">
            {
                categorias.slice(0, 4).map((categoria, index) => {
                    const icons = [
                        <Leaf color="#3A5A40" size={24} />,
                        <Gift color="#3A5A40" size={24} />,
                        <Sprout color="#3A5A40" size={24} />,
                        <Scissors color="#3A5A40" size={24} />,
                    ];
                    // La solución completa: Crear la página dinámica src/pages/categoria/[slug].astro. Esto implica crear un nuevo archivo que:
                    // Le diga a Astro todas las slugs de categorías que existen.
                    // Para cada slug, obtenga los productos de esa categoría desde Strapi.
                    // Muestre esos productos en una página. Esta es la solución "correcta" a largo plazo, pero es más compleja.
                    // Por ahora, el enlace se ha convertido en un <div> para evitar errores 404.
                    return (
                        <a href={`/categoria/${categoria.slug}`} class="filter-item">
                            <span class="icon">
                                {icons[index % icons.length]}
                            </span>
                            <span>{categoria.nombre}</span>
                        </a>
                    );
                })
            }
        </div>
    </section>

    <div class="container">
        <div class="products-header">
            <p class="products-count">
                {`${productos.length} productos`}
            </p>
            <div class="view-switcher">
                <button id="grid-view-btn" class="view-btn active">
                    <Grid size={20} />
                    <span>Grid</span>
                </button>
                <button id="list-view-btn" class="view-btn">
                    <List size={20} />
                    <span>List</span>
                </button>
            </div>
        </div>
    </div>

    <!-- Contenedor principal para la vista de productos -->
    <div id="products-container">
        <!-- Vista de Grid (Carruseles) -->
        <div id="grid-view-content">
            {
                carruseles.map(
                    ([nombreCategoria, productosDeCategoria], index) => (
                        <>
                            <ProductCarousel
                                title={nombreCategoria}
                                products={productosDeCategoria}
                            />
                            {index === 1 && (
                                <section class="promo-banner">
                                    <div class="container banner-content">
                                        <div class="banner-text">
                                            <span class="promo-badge">
                                                NUEVO
                                            </span>
                                            <h2>COLECCIÓN SUCULENTAS</h2>
                                            <p>
                                                Descubre nuestra nueva selección
                                                de suculentas exóticas. Fáciles
                                                de cuidar, hermosas y perfectas
                                                para espacios interiores.
                                            </p>
                                            <a href="/" class="btn btn-primary">
                                                QUIERO COMPRAR
                                            </a>
                                        </div>
                                    </div>
                                </section>
                            )}
                        </>
                    ),
                )
            }
        </div>

        <!-- Vista de Lista (Simple pero genial y comodo) -->
        <div id="list-view-content" class="container" style="display: none;">
            <div class="list-view">
                {
                    productos.map((producto) => (
                        <div
                            class="product-wrapper"
                            data-category={producto.categoria?.slug}
                            data-name={producto.nombre.toLowerCase()}
                        >
                            <ProductCard producto={producto} />
                        </div>
                    ))
                }
            </div>
        </div>
    </div>
</Layout>

<script is:inline>
    function initIndexPage() {
        const gridViewBtn = document.getElementById("grid-view-btn");
        const listViewBtn = document.getElementById("list-view-btn");
        const gridViewContent = document.getElementById("grid-view-content");
        const listViewContent = document.getElementById("list-view-content");
        const searchInput = document.querySelector(".search-input");
        const productWrappers = document.querySelectorAll(
            "#list-view-content .product-wrapper",
        );

                        const savedView = localStorage.getItem("homeView") === "list" ? "list" : "grid";

        /** @param {'grid' | 'list'} view */
        function updateTransitionNames(view) {
            const images = document.querySelectorAll("img[data-product-slug]");
            images.forEach((el) => {
                const img = /** @type {HTMLElement} */ (el);
                const slug = img.getAttribute("data-product-slug");
                if (!slug) return;

                // Determinar si esta imagen está dentro de la vista activa
                const isInActiveView =
                    view === "list"
                        ? img.closest("#list-view-content") !== null
                        : img.closest("#grid-view-content") !== null;

                if (isInActiveView) {
                    img.style.setProperty(
                        "view-transition-name",
                        `image-${slug}`,
                    );
                } else {
                    img.style.removeProperty("view-transition-name");
                }
            });
        }

                /** @param {'grid' | 'list'} view */
        function applyView(view) {
            if (view === "list") {
                if (gridViewContent) gridViewContent.style.display = "none";
                if (listViewContent) listViewContent.style.display = "block";
                if (listViewBtn) listViewBtn.classList.add("active");
                if (gridViewBtn) gridViewBtn.classList.remove("active");
            } else {
                if (gridViewContent) gridViewContent.style.display = "block";
                if (listViewContent) listViewContent.style.display = "none";
                if (gridViewBtn) gridViewBtn.classList.add("active");
                if (listViewBtn) listViewBtn.classList.remove("active");
            }
            updateTransitionNames(view);
        }

        /** @param {string} searchTerm */
        function filterProducts(searchTerm) {
            const term = searchTerm.toLowerCase();
            productWrappers.forEach((wrapper) => {
                const el = /** @type {HTMLElement} */ (wrapper);
                const name = el.dataset.name || "";
                if (name.includes(term)) {
                    el.style.display = "block";
                } else {
                    el.style.display = "none";
                }
            });
        }

        applyView(savedView);

        if (gridViewBtn) {
            gridViewBtn.addEventListener("click", () => {
                applyView("grid");
                localStorage.setItem("homeView", "grid");
            });
        }

        if (listViewBtn) {
            listViewBtn.addEventListener("click", () => {
                applyView("list");
                localStorage.setItem("homeView", "list");
            });
        }

        if (searchInput) {
            searchInput.addEventListener("input", (e) => {
                const input = /** @type {HTMLInputElement} */ (e.target);
                const searchTerm = input.value;
                if (searchTerm.length > 0) {
                    applyView("list"); // Forzar vista de lista al buscar
                }
                filterProducts(searchTerm);
            });
        }
    }

    // Inicializar tanto en carga inicial como en navegaciones de Astro ClientRouter
    document.addEventListener("astro:page-load", initIndexPage);
</script>

<style>
    /* Hero Section Overrides */
    .hero-section {
        padding-bottom: 50px; /* Top padding to account for fixed header */
        background-image: url("/images/bg-hero-b.jpg");
    }

    .hero-desc {
        max-width: 600px;
    }

    /* Buscador */
    .search-container {
        position: absolute;
        bottom: 0;
        left: 50%;
        transform: translate(
            -50%,
            50%
        ); /* Moves it down 50% of its own height to overlap */
        width: 90%;
        max-width: 600px;
        z-index: 20;
    }

    .search-form {
        display: flex;
        background: white;
        border-radius: var(--radius-full);
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
        padding: 5px;
        border: 1px solid #eee;
        gap: 8px;
    }

    .search-input {
        flex: 1;
        border: none;
        padding: 8px 25px;
        border-radius: var(--radius-full);
        outline: none;
    }

    .search-btn {
        background-color: var(--color-primary-dark);
        color: white;
        border: none;
        padding: 8px 30px;
        border-radius: 9999px;
        font-weight: 500;
        letter-spacing: 1px;
        cursor: pointer;
        transition: background-color 0.3s;
    }

    .search-btn:hover {
        background-color: var(--color-primary);
    }

    /* Filtros Rápidos */
    .quick-filters {
        margin-top: 100px; /* Space for the floating search bar */
        margin-bottom: 60px;
    }

    .filter-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
    }

    .filter-item {
        background: #e8f1e9; /* Fondo gris verdoso suave */
        font-size: 16px;
        padding: 20px;
        border-radius: var(--radius-md);
        display: flex;
        align-items: center;
        gap: 15px;
        position: relative;
        cursor: pointer;
        transition: transform 0.3s;
        text-decoration: none;
        color: inherit;
    }

    .filter-item:hover {
        transform: translateY(-5px);
    }

    .badg-disc {
        position: absolute;
        top: -10px;
        left: 10px;
        background: #00c896; /* Verde chillón oferta */
        border-radius: 10px;
        color: white;
        font-size: 0.6rem;
        font-weight: 500;
        line-height: 0.4rem;
        padding: 6px 8px;
        position: absolute;
    }

    .icon {
        font-size: 1.5rem;
    }

    /* Banner Promocional */
    .promo-banner {
        background:
            linear-gradient(rgba(255, 255, 255, 0.7), rgba(255, 255, 255, 0.7)),
            url("/banner-bg.jpg");
        background-size: cover;
        background-position: center;
        background-attachment: fixed;
        padding: 80px 0;
        margin-bottom: 60px;
        position: relative;
        overflow: hidden;
    }

    .banner-content {
        position: relative;
        z-index: 2;
    }

    .promo-badge {
        background: #00c896;
        color: white;
        padding: 5px 10px;
        font-size: 0.7rem;
        font-weight: 500;
        border-radius: 4px;
        margin-bottom: 15px;
        display: inline-block;
    }

    .banner-text {
        max-width: 500px;
    }

    .banner-text h2 {
        font-size: 2.5rem;
        margin-bottom: 20px;
        color: var(--color-primary-dark);
    }

    .banner-text p {
        margin-bottom: 30px;
        color: var(--color-text-light);
    }

    .products-header {
        margin-bottom: var(--space-6);
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .view-switcher {
        display: flex;
        gap: 10px;
    }

    .view-btn {
        display: flex;
        align-items: center;
        gap: 8px;
        background: none;
        border: 1px solid #ccc;
        padding: 8px 16px;
        cursor: pointer;
        border-radius: var(--radius-md);
        transition: all 0.3s ease;
    }

    .view-btn:hover {
        background: #f0f0f0;
    }

    .view-btn.active {
        background: var(--color-primary);
        color: white;
        border-color: var(--color-primary);
    }

    .list-view {
        display: flex;
        flex-direction: column;
        gap: var(--space-4);
    }

    .list-view > .product-wrapper > :global(.product-card) {
        display: grid;
        grid-template-columns: 100px 1fr; /* Ajustado para dos columnas principales */
        align-items: center;
        gap: var(--space-6);
        background: white;
        padding: var(--space-4); /* Añadido padding para espaciado interno */
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-sm);
    }

    .list-view > .product-wrapper > :global(.product-card .image-wrapper) {
        width: 100px;
        height: 100px;
        margin-bottom: 0;
        border-radius: var(--radius-md); /* Bordes redondeados para la imagen */
    }

    .list-view > .product-wrapper > :global(.product-card .image-wrapper img) {
        object-fit: cover;
    }

    .list-view > .product-wrapper > :global(.product-card .card-content) {
        display: grid;
        grid-template-columns: 1fr auto; /* 2 columns: info and details */
        align-items: center;
        gap: var(--space-4);
        width: 100%;
    }

    .list-view > .product-wrapper > :global(.product-card .product-button-col) {
        padding: 6px 12px;
        font-size: 0.7rem;
        white-space: nowrap; /* Prevent text from wrapping */
        margin-top: var(--space-2); /* Add space above the button */
    }

    .list-view > .product-wrapper > :global(.product-card .product-info-col) {
        text-align: left;
    }

    .list-view > .product-wrapper > :global(.product-card .rating) {
        justify-content: flex-start;
    }

    .list-view
        > .product-wrapper
        > :global(.product-card .product-details-col) {
        display: flex;
        flex-direction: column; /* Apilar precio y stock */
        align-items: flex-end; /* Alinear a la derecha */
        justify-content: center; /* Centrar verticalmente */
        gap: var(--space-2);
        height: 100%;
    }

    .list-view > .product-wrapper > :global(.product-card .product-price) {
        font-size: var(--text-sm);
        font-weight: bold;
        color: var(--color-text-light);
        margin-bottom: 0;
    }

    .list-view > .product-wrapper > :global(.product-card .stock-info) {
        font-size: 0.9rem;
        color: var(--color-primary);
        margin-bottom: 0;
    }

    .list-view > .product-wrapper > :global(.product-card .card-badges) {
        top: 10px;
        left: 10px;
    }

    @media (max-width: 768px) {
        .hero-section {
            padding: 100px 0 10px;
            padding-bottom: 50px;
            text-align: center;
            background-size: cover;
            background-position: center bottom;
            background-repeat: no-repeat;
            position: relative;
            margin-bottom: 0;
            margin-top: 0;
        }
        .quick-filters {
        margin-top: 60px; /* Space for the floating search bar */
        margin-bottom: 20px;
        }
        .search-form{
            padding: 8px;
        }
        .search-btn {
            padding: 6px 20px;
            font-size: 0.7rem;
        }
        .filter-grid {
            grid-template-columns: 1fr 1fr;
            gap: 8px;
        }
        .view-btn {
            padding: 6px 16px;
            font-size: 0.8rem;
            border-radius: 50px;
        }
        .hero-title {
            font-size: 1.5rem;
            text-transform: none;
            margin: 8px 0;
            letter-spacing: 0px;
        }
        .hero-subtitle {
            font-size: .6rem;
        }
        .hero-desc {
            max-width: 350px;
            margin: 0 auto 0px;
            font-size: 1rem;
        }
        .filter-item {
            font-size: 13px;
            padding: 8px;
            border-radius: 50px;
            gap: 8px;
        }
        .icon svg{
            display: block;
            max-width: 80%;
        }
        .products-header{
            border-top: 1px solid #aec8b33c;
            border-bottom: 1px solid #aec8b33c;
            padding-top: 4px;
            padding-bottom: 4px;
        }
        .view-btn {
            font-size: 15px;
            padding: 6px 16px;
            border-radius: 50px;
        }
        .list-view > .product-wrapper > :global(.product-card) {
            gap: var(--space-4);
            background: white;
            border-radius: var(--radius-lg);
            box-shadow: var(--shadow-sm);
            padding: 10px;
        }
    }
</style>