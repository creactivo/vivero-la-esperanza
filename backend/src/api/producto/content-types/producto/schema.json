{
  "kind": "collectionType",
  "collectionName": "productos",
  "info": {
    "singularName": "producto",
    "pluralName": "productos",
    "displayName": "Productos"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "nombre": {
      "type": "string",
      "required": true
    },
    "descripcion": {
      "type": "text",
      "required": true
    },
    "precio": {
      "type": "decimal",
      "required": true
    },
    "precioMayorista": {
      "type": "decimal",
      "required": true
    },
    "cantidadMinima": {
      "type": "integer",
      "required": true
    },
    "stock": {
      "type": "integer",
      "required": true,
      "default": 0
    },
    "slug": {
      "type": "uid",
      "targetField": "nombre",
      "required": true
    },
    "activo": {
      "type": "boolean",
      "default": true
    },
    "imagenes": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images"
      ]
    },
    "categoria": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::categoria.categoria",
      "inversedBy": "productos"
    }
  }
}
